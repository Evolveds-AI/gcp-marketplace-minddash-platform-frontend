// Schema de Recuperación - Combina nuevos modelos de autenticación con modelos perdidos
// Este schema permite recuperar los datos perdidos manteniendo el sistema de autenticación

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// MODELOS DE AUTENTICACIÓN (NUEVOS)
// ================================

model EMPRESAS {
  id          String @id @default(uuid())
  nombre      String
  descripcion String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  // Relations
  usuarios    USUARIOS[]
  
  @@map("empresas")
}

model USUARIOS {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  password_hash String
  iam_role      String   @default("user") // 'admin' | 'user'
  empresa_id    String
  email_verified Boolean @default(false)
  is_active     Boolean @default(true)
  failed_attempts Int   @default(0)
  locked_until    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  
  // Relations
  empresa       EMPRESAS @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  password_resets PASSWORD_RESETS[]
  sessions_user SESSIONS_USER[]
  events        SESSIONS_EVENTS[]
  
  // Relations con modelos recuperados
  messages      Message[]
  user_states   UserState[]
  events_old    Event[]
  
  @@map("usuarios")
}

model PASSWORD_RESETS {
  id         String   @id @default(uuid())
  usuario_id String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  
  // Relations
  usuario    USUARIOS @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  @@map("password_resets")
}

model SESSIONS_USER {
  id         String   @id @default(uuid())
  usuario_id String
  jwt_token  String   @unique
  refresh_token String @unique
  expires_at DateTime
  refresh_expires_at DateTime
  is_active  Boolean  @default(true)
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())
  
  // Relations
  usuario    USUARIOS @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  @@map("sessions_user")
}

model SESSIONS_EVENTS {
  id         String   @id @default(uuid())
  usuario_id String
  content    String
  role       String   // 'user' | 'assistant' | 'system'
  timestamp  DateTime @default(now())
  
  // Relations
  usuario    USUARIOS @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  @@map("sessions_events")
}

// ================================
// MODELOS PERDIDOS (RECUPERACIÓN)
// ================================

// Modelo Message - Historial de conversaciones (509 filas perdidas)
model Message {
  id          String   @id @default(uuid())
  role        String   // 'user' | 'assistant' | 'system'
  type        String   // 'user' | 'assistant' | 'function' | 'error'
  content     String   @db.Text
  chart       String?  // URL del gráfico si existe
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String?
  functionName String?
  functionDetails Json?
  errorDetails Json?
  error       String?  @db.Text
  isEdited    Boolean  @default(false)
  isUpdatedResponse Boolean @default(false)
  
  // Relaciones opcionales para migración gradual
  usuario_id  String?
  usuario     USUARIOS? @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  // Para compatibilidad con localStorage
  conversation_id String?
  client_name     String? // gcpName del cliente
  
  @@map("messages")
}

// Modelo UserWpp - Datos de usuarios WhatsApp (8 filas perdidas)
model UserWpp {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?
  is_active Boolean  @default(true)
  metadata  Json?    // Datos adicionales
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("user_wpp")
}

// Modelo AppStates - Estados de aplicación (1 fila perdida)
model AppStates {
  id        String   @id @default(uuid())
  key       String   @unique // Clave del estado
  value     Json     // Valor del estado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("app_states")
}

// Modelo Event - Eventos del sistema (6 filas perdidas)
model Event {
  id        String   @id @default(uuid())
  type      String   // Tipo de evento
  data      Json     // Datos del evento
  timestamp DateTime @default(now())
  
  // Relación opcional con usuario
  usuario_id String?
  usuario    USUARIOS? @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  @@map("events")
}

// Modelo UserState - Estados de usuario (1 fila perdida)
model UserState {
  id        String   @id @default(uuid())
  state     Json     // Estado del usuario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relación opcional con usuario
  usuario_id String?
  usuario    USUARIOS? @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  
  @@map("user_states")
}

// ================================
// MODELOS ADICIONALES (COMPATIBILIDAD)
// ================================

// Para mantener compatibilidad con el sistema de conversaciones
model Conversation {
  id        String   @id @default(uuid())
  title     String
  lastMessage String @db.Text
  timestamp DateTime @default(now())
  client_name String // gcpName del cliente
  usuario_id String?
  
  @@map("conversations")
} 