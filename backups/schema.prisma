generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Message {
  id        String    @id
  text      String?
  userId    String?
  createdAt DateTime? @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)
}

model Product {
  id          String        @id
  nombre      String
  client_id   String
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime
  clients     clients       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  ProductUser ProductUser[]
}

model ProductUser {
  id         String   @id
  product_id String
  user_id    String
  action     String
  timestamp  DateTime @default(now())
  Product    Product  @relation(fields: [product_id], references: [id])
  usuarios   usuarios @relation(fields: [user_id], references: [id])
}

model Roles {
  id      String @id
  user_id String
  nivel   String
  scope   String
}

model RolesAcDatos {
  id       String   @id
  user_id  String
  tabla    String
  campo    String
  valor    String
  usuarios usuarios @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model UserWpp {
  id          String   @id
  phoneNumber String   @unique
  name        String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @db.Timestamp(6)
}

model app_states {
  app_name    String   @id @db.VarChar(128)
  state       Json
  update_time DateTime @db.Timestamp(6)
}

model chatbot_owners {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  usuario_id   String
  chatbot_id   String
  chatbot_name String
  company_name String
  permissions  Json?     @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
  usuarios     usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chatbot_owner_user")

  @@unique([usuario_id, chatbot_id], map: "unique_user_chatbot")
}

model clients {
  id          String     @id(map: "empresas_pkey")
  nombre      String
  descripcion String?
  created_at  DateTime   @default(now())
  updated_at  DateTime
  Product     Product[]
  PRODUCT     PRODUCT[]
  usuarios    usuarios[]
}

model conversations {
  id          String   @id
  title       String
  lastMessage String
  timestamp   DateTime @default(now())
  client_name String
  usuario_id  String?
}

model events {
  id                         String   @db.VarChar(128)
  app_name                   String   @db.VarChar(128)
  user_id                    String   @db.VarChar(128)
  session_id                 String   @db.VarChar(128)
  invocation_id              String   @db.VarChar(256)
  author                     String   @db.VarChar(256)
  branch                     String?  @db.VarChar(256)
  timestamp                  DateTime @db.Timestamp(6)
  content                    Json?
  actions                    Bytes
  long_running_tool_ids_json String?
  grounding_metadata         Json?
  partial                    Boolean?
  turn_complete              Boolean?
  error_code                 String?  @db.VarChar(256)
  error_message              String?  @db.VarChar(1024)
  interrupted                Boolean?
  sessions                   sessions @relation(fields: [app_name, user_id, session_id], references: [app_name, user_id, id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id, app_name, user_id, session_id])
}

model password_resets {
  id         String   @id
  usuario_id String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model sessions {
  app_name    String   @db.VarChar(128)
  user_id     String   @db.VarChar(128)
  id          String   @db.VarChar(128)
  state       Json
  create_time DateTime @db.Timestamp(6)
  update_time DateTime @db.Timestamp(6)
  events      events[]

  @@id([app_name, user_id, id])
}

model sessions_events {
  id         String   @id
  usuario_id String
  content    String
  role       String
  timestamp  DateTime @default(now())
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model sessions_user {
  id                 String   @id
  usuario_id         String
  jwt_token          String   @unique
  refresh_token      String   @unique
  expires_at         DateTime
  refresh_expires_at DateTime
  is_active          Boolean  @default(true)
  ip_address         String?
  user_agent         String?
  created_at         DateTime @default(now())
  usuarios           usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model user_chatbots {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar
  usuario_id   String   @db.VarChar
  chatbot_id   String   @db.VarChar
  chatbot_name String   @db.VarChar
  chatbot_path String   @db.VarChar
  gcp_name     String   @db.VarChar
  is_active    Boolean  @default(true)
  assigned_at  DateTime @default(now()) @db.Timestamp(6)
  assigned_by  String   @db.VarChar
  usuarios     usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuario_id, chatbot_id])
}

model user_states {
  app_name    String   @db.VarChar(128)
  user_id     String   @db.VarChar(128)
  state       Json
  update_time DateTime @db.Timestamp(6)

  @@id([app_name, user_id])
}

model PRODUCT {
  id         String   @id @default(uuid())
  nombre     String
  client_id  String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  client     clients   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  actions    PRODUCT_USER[]
}

model PRODUCT_USER {
  id         String   @id @default(uuid())
  product_id String
  user_id    String
  action     String   // create | modify | delete
  timestamp  DateTime @default(now())

  product    PRODUCT  @relation(fields: [product_id], references: [id])
  user       usuarios @relation(fields: [user_id], references: [id])
}

model ROLES_AC_DATOS {
  id       String @id @default(uuid())
  user_id  String
  tabla    String
  campo    String
  valor    String

  user     usuarios @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model usuarios {
  id                 String            @id
  username           String            @unique
  email              String            @unique
  password_hash      String
  iam_role           String            @default("user")
  client_id          String
  email_verified     Boolean           @default(false)
  is_active          Boolean           @default(true)
  failed_attempts    Int               @default(0)
  locked_until       DateTime?
  created_at         DateTime          @default(now())
  updated_at         DateTime
  role_type          String?           @db.VarChar(50)
  primary_chatbot_id String?           @db.VarChar(255)
  can_manage_users   Boolean?          @default(false)
  ProductUser        ProductUser[]
  RolesAcDatos       RolesAcDatos[]
  PRODUCT_USER       PRODUCT_USER[]
  ROLES_AC_DATOS     ROLES_AC_DATOS[]
  chatbot_owners     chatbot_owners[]
  password_resets    password_resets[]
  sessions_events    sessions_events[]
  sessions_user      sessions_user[]
  user_chatbots      user_chatbots[]
  clients            clients           @relation(fields: [client_id], references: [id], onDelete: Cascade)
}