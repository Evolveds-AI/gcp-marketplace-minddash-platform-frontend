      "get": {
        "tags": [
          "Semantic Layer"
        ],
        "summary": "Describir YAML como JSON para el frontend",
        "description": "Carga el archivo YAML desde GCS y devuelve una **representación JSON** optimizada y parseada (solo *datasets* y sus atributos), ideal para su consumo directo por interfaces de usuario.",
        "operationId": "describe_layer_semantic_layer_describe_get",
        "parameters": [
          {
