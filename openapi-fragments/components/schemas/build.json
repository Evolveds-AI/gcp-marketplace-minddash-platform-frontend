          "title": "Time Dimension Candidates",
          "default": [
            "fecha",
            "date",
            "created_at",
            "updated_at",
            "timestamp",
            "fecha_factura"
          ]
        },
        "engine": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "postgres",
                "mysql",
                "bigquery",
                "databricks",
                "mariadb",
                "mssql",
                "synapsemssql",
                "redshift",
                "snowflake",
                "aurora",
                "aurorapostgres",
                "auroramysql",
                "hana",
                "oracle",
                "teradata",
                "clickhouse"
              ]
            },
            {
              "type": "null"
            }
          ],
          "title": "Engine",
          "default": "postgres"
        },
        "include_profiling": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Include Profiling",
          "default": false
