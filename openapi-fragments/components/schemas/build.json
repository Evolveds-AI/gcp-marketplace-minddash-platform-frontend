        "bucket_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Bucket Name"
        },
        "object_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Object Path"
        },
        "databricks_config": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/DatabricksConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object",
      "required": [
        "server_url",
        "database",
        "selections"
      ],
      "title": "BuildRequest"
    }
  }
