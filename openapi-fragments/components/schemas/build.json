        "server_url": {
          "type": "string",
          "title": "Server Url"
        },
        "product_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Product Id"
        },
        "database": {
          "type": "string",
          "title": "Database"
        },
        "selections": {
          "items": {
            "$ref": "#/components/schemas/ColumnSelection"
          },
          "type": "array",
          "title": "Selections"
        },
        "infer_types": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Infer Types",
          "default": true
        },
        "add_default_measures": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Add Default Measures",
          "default": true
        },
        "time_dimension_candidates": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
