          "title": "Product Id"
        },
        "bucket_name": {
          "type": "string",
          "title": "Bucket Name"
        },
        "examples_yaml_path": {
          "type": "string",
          "title": "Examples Yaml Path"
        },
        "embeddings_npy_path": {
          "type": "string",
          "title": "Embeddings Npy Path"
        },
        "model_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
