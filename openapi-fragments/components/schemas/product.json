        "is_active_insight": false,
        "is_active_rag": true,
        "label": "SALES-BOT",
        "label_color": "#008000",
        "language": "en",
        "max_users": 200,
        "name": "Chatbot de Ventas",
        "project_id": "a6f38618-4308-4dfc-83d7-4f98651649c1",
