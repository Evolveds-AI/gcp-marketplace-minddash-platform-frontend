{
  "schemas": {
    "Project": {
      "properties": {
        "user_id": {
          "type": "string",
          "title": "User Id",
          "description": "str del usuario."
        },
        "user_role_name": {
          "type": "string",
          "title": "User Role Name",
          "description": "Nombre del rol más efectivo del usuario en la jerarquía (ej. 'SuperAdmin')."
        },
        "user_name": {
          "type": "string",
          "title": "User Name",
          "description": "Nombre completo del usuario."
        },
        "user_phone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "User Phone",
          "description": "Número de teléfono del usuario."
        },
        "user_email": {
          "type": "string",
          "format": "email",
          "title": "User Email",
          "description": "Correo electrónico del usuario."
        },
        "organization_id": {
          "type": "string",
          "title": "Organization Id",
          "description": "str de la Proyecto a la que pertenece el proyecto."
        },
        "organization_name": {
          "type": "string",
          "title": "Organization Name",
          "description": "Nombre de la Proyecto."
        },
        "project_id": {
          "type": "string",
          "title": "Project Id",
          "description": "str del proyecto."
        },
        "project_name": {
          "type": "string",
          "title": "Project Name",
          "description": "Nombre del proyecto."
        },
        "project_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Project Label",
          "description": "Etiqueta del proyecto."
        },
        "project_label_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Project Label Color",
          "description": "Color de la etiqueta del proyecto (ej. #2ecc71)."
        },
        "project_description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Project Description",
          "description": "Descripción del proyecto."
        }
      },
      "type": "object",
      "required": [
        "user_id",
        "user_role_name",
        "user_name",
        "user_email",
        "organization_id",
        "organization_name",
        "project_id",
        "project_name"
      ],
      "title": "Project",
      "description": "Representa una tupla de acceso a un Proyecto para un usuario específico,\nincluyendo la jerarquía superior (Organización)."
    },
