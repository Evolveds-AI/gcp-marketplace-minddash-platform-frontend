    "ProjectCreationAccessResponse": {
      "properties": {
        "project_access_id": {
          "type": "string",
          "title": "Project Access Id",
          "description": "UUID del nuevo registro de acceso creado."
        }
      },
      "type": "object",
      "required": [
        "project_access_id"
      ],
      "title": "ProjectCreationAccessResponse",
      "description": "Respuesta para el registro exitoso."
    },
    "ProjectCreationResponse": {
      "properties": {
        "id_project": {
          "type": "string",
