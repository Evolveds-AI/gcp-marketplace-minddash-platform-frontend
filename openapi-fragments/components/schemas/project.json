        "id_project"
      ],
      "title": "ProjectCreationResponse"
    },
    "ProjectDeleteAccessRequest": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "UUID del registro de acceso a eliminar (access_user_project.id)."
        }
      },
      "type": "object",
      "required": [
        "id"
      ],
      "title": "ProjectDeleteAccessRequest",
      "description": "Modelo para la entrada de datos al eliminar un registro de acceso (DELETE).\nSolo requiere el ID del registro de acceso."
    },
    "ProjectDeleteAccessResponse": {
      "properties": {
        "message": {
          "type": "string",
          "title": "Message",
          "default": "Acceso a organización eliminado exitosamente."
        },
        "project_access_id": {
          "type": "string",
          "title": "Project Access Id",
          "description": "UUID del registro de acceso eliminado."
        }
      },
      "type": "object",
      "required": [
        "project_access_id"
      ],
      "title": "ProjectDeleteAccessResponse",
      "description": "Respuesta para la eliminación exitosa."
    },
    "ProjectDeleteRequest": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "ID del proyecto que se va a eliminar."
        }
      },
      "type": "object",
      "required": [
        "id"
      ],
      "title": "ProjectDeleteRequest",
      "description": "Datos necesarios para llamar a spu_minddash_app_delete_project.\nSolo requiere el ID.",
      "example": {
        "id": "46c1189b-0670-47db-b764-5b5df74d0ace"
      }
    },
    "ProjectDeleteResponse": {
      "properties": {
        "message": {
          "type": "string",
          "title": "Message",
          "description": "Mensaje de confirmación.",
          "default": "Organización eliminada exitosamente."
        },
        "project_id": {
          "type": "string",
          "title": "Project Id",
          "description": "str de la Proyecto eliminada."
        }
      },
      "type": "object",
      "required": [
        "project_id"
      ],
      "title": "ProjectDeleteResponse"
    },
    "ProjectRegisterAccessRequest": {
      "properties": {
        "user_id": {
          "type": "string",
          "title": "User Id",
          "description": "UUID del usuario al que se le da acceso."
        },
        "project_id": {
          "type": "string",
          "title": "Project Id",
          "description": "UUID de la organización a la que se da acceso."
        },
        "role_id": {
          "type": "string",
          "title": "Role Id",
          "description": "UUID del rol que se asigna en esa organización."
        }
      },
      "type": "object",
      "required": [
        "user_id",
        "project_id",
        "role_id"
      ],
      "title": "ProjectRegisterAccessRequest",
      "description": "Modelo para la entrada de datos al registrar un nuevo acceso (INSERT).\nCorresponde a los parámetros del SP: user_id, project_id, role_id."
    },
    "ProjectRegisterRequest": {
      "properties": {
        "organization_id": {
          "type": "string",
          "title": "Organization Id",
          "description": "ID de la organización a la que pertenece el proyecto."
        },
        "name": {
          "type": "string",
          "maxLength": 50,
          "title": "Name",
          "description": "Nombre del proyecto (máx. 50 caracteres)."
        },
        "label": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 50
            },
            {
              "type": "null"
            }
          ],
          "title": "Label",
          "description": "Etiqueta corta del proyecto (ej: 'ALFA-2025')."
        },
        "label_color": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 20
            },
            {
              "type": "null"
            }
          ],
          "title": "Label Color",
          "description": "Código de color para la etiqueta (ej: '#007bff')."
        },
        "description": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ],
          "title": "Description",
          "description": "Descripción detallada del proyecto (máx. 200 caracteres)."
        }
      },
      "type": "object",
      "required": [
        "organization_id",
        "name"
      ],
      "title": "ProjectRegisterRequest",
      "description": "Datos necesarios para llamar a spu_minddash_app_insert_project.",
      "example": {
        "description": "Desarrollo de la fase inicial de la plataforma de datos.",
        "label": "NEP-2026",
        "label_color": "#ffc107",
        "name": "Proyecto Neptuno",
        "organization_id": "e7c77bdf-8f8e-438c-b038-5ea9253e0ad7"
      }
    },
    "ProjectUpdateAccessRequest": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "UUID del registro de acceso a actualizar (access_user_project.id)."
        },
        "user_id": {
          "type": "string",
          "title": "User Id",
          "description": "Nuevo UUID del usuario (generalmente el mismo)."
        },
        "project_id": {
          "type": "string",
          "title": "Project Id",
          "description": "Nuevo UUID de la organización (generalmente el mismo)."
        },
        "role_id": {
          "type": "string",
          "title": "Role Id",
          "description": "Nuevo UUID del rol que se asigna."
        }
      },
      "type": "object",
      "required": [
        "id",
        "user_id",
        "project_id",
        "role_id"
      ],
      "title": "ProjectUpdateAccessRequest",
      "description": "Modelo para la entrada de datos al actualizar un registro de acceso existente (UPDATE).\nCorresponde a los parámetros del SP: id, user_id, project_id, role_id."
    },
    "ProjectUpdateAccessResponse": {
      "properties": {
        "message": {
          "type": "string",
          "title": "Message",
          "default": "Acceso a organización actualizado exitosamente."
        },
        "project_access_id": {
          "type": "string",
          "title": "Project Access Id",
          "description": "UUID del registro de acceso actualizado."
        }
      },
      "type": "object",
      "required": [
        "project_access_id"
      ],
      "title": "ProjectUpdateAccessResponse",
      "description": "Respuesta para la actualización exitosa."
    },
    "ProjectUpdateRequest": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "ID del proyecto que se va a actualizar."
        },
        "organization_id": {
          "type": "string",
          "title": "Organization Id",
          "description": "ID de la organización (puede ser el mismo o uno nuevo)."
        },
        "name": {
          "type": "string",
          "maxLength": 50,
          "title": "Name",
          "description": "Nuevo nombre del proyecto."
        },
        "label": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 50
            },
            {
              "type": "null"
            }
          ],
          "title": "Label",
          "description": "Nueva etiqueta del proyecto."
        },
        "label_color": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 20
            },
            {
              "type": "null"
            }
          ],
          "title": "Label Color",
          "description": "Nuevo código de color."
        },
        "description": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ],
          "title": "Description",
          "description": "Nueva descripción del proyecto."
        }
      },
      "type": "object",
      "required": [
        "id",
        "organization_id",
        "name"
      ],
      "title": "ProjectUpdateRequest",
      "description": "Datos necesarios para llamar a spu_minddash_app_update_project.\nTodos los campos son obligatorios para la actualización completa.",
      "example": {
        "description": "Se actualizó la descripción para reflejar el inicio de la fase beta.",
        "id": "46c1189b-0670-47db-b764-5b5df74d0ace",
        "label": "NEP-BETA",
        "label_color": "#17a2b8",
        "name": "Proyecto Neptuno (Fase Beta)",
        "organization_id": "e7c77bdf-8f8e-438c-b038-5ea9253e0ad7"
      }
    },
    "ProjectUpdateResponse": {
      "properties": {
        "message": {
          "type": "string",
          "title": "Message",
          "description": "Mensaje de confirmación.",
          "default": "Organización actualizada exitosamente."
        },
        "project_id": {
          "type": "string",
          "title": "Project Id",
          "description": "str de la Proyecto actualizada."
        }
      },
      "type": "object",
      "required": [
        "project_id"
      ],
      "title": "ProjectUpdateResponse"
    }
  }
}
