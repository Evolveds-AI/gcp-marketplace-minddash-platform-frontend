          "description": "Ruta del Google Storage para profiling del agente."
        },
        "gs_metrics_config_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Gs Metrics Config Agent",
          "description": "Ruta del Google Storage para configuración de métricas."
        },
        "client": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Client",
          "description": "Nombre o ID del cliente (campo 'client')."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "title": "Created At",
          "description": "Fecha de creación."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "title": "Updated At",
          "description": "Fecha de última actualización."
        }
      },
      "type": "object",
      "required": [
        "id",
        "product_id",
        "created_at",
        "updated_at"
      ],
      "title": "ClientDeployData",
      "description": "Modelo para representar un registro de clients_products_deploys."
    },
    "ClientDeployDeleteRequest": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "ID del registro a eliminar."
        }
      },
      "type": "object",
      "required": [
        "id"
      ],
      "title": "ClientDeployDeleteRequest",
      "description": "Datos necesarios para la eliminación.",
      "example": {
        "id": "1ee67952-ef83-4038-ae9d-d95d2f16c32e"
      }
    },
    "ClientDeployDeleteResponse": {
      "properties": {
        "message": {
          "type": "string",
