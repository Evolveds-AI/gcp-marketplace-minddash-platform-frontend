          "description": "ID del nuevo registro de despliegue creado."
        }
      },
      "type": "object",
      "required": [
        "id_deploy"
      ],
      "title": "ClientDeployCreationResponse"
    },
    "ClientDeployData": {
      "properties": {
        "id": {
          "type": "string",
          "title": "Id",
          "description": "str del registro de despliegue."
        },
        "product_id": {
          "type": "string",
          "title": "Product Id",
          "description": "str del producto asociado."
        },
        "bucket_config": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
