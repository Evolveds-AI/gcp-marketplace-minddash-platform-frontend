  Mes                 BigInt?
  Year                BigInt?
  ProfitCode          BigInt?
  PrcName             String?
  U_NX_CtaCOGES       BigInt?
  Account             BigInt?
  AcctName            String?
  Memo                String?
  Saldo               Float?
  U_CC_ESP            String?
  U_CLASIF            String?
  Nombre_Mes          String? @map("Nombre Mes")
  Concepto            String?
