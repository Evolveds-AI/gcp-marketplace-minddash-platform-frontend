  profit_code         String?  @db.VarChar(50)
  prc_name            String?  @db.VarChar(255)
  u_nx_ctacoges       String?  @db.VarChar(255)
  account             String?  @db.VarChar(50)
  acct_name           String?  @db.VarChar(255)
  memo                String?
