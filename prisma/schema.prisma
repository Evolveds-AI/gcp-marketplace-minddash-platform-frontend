  Orden_Concep_Compac BigInt? @map("Orden Concep Compac")
  Concepto_Compacto   String? @map("Concepto Compacto")
  Epigrafe            String?

  @@ignore
}

model roles {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                     String?                    @db.VarChar(50)
  type_role                String?                    @db.VarChar(50)
  description              String?
  created_at               DateTime                   @default(now())
  updated_at               DateTime?
  users                    users[]
  access_user_client       access_user_client[]
  access_user_organization access_user_organization[]
  access_user_product      access_user_product[]
  access_user_project      access_user_project[]
}

model roles_data_access {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id       String             @db.Uuid
  name             String             @db.VarChar(255)
  table_names      String[]
  data_access      Json?
  metrics_access   Json?
  created_at       DateTime           @default(now())
  updated_at       DateTime
  products         products           @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "roles_data_access_products_fkey")
  user_data_access user_data_access[]
}

model semantic_layer_configs {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id        String   @db.Uuid
  server_url        String   @db.VarChar(255)
  database_name     String   @db.VarChar(255)
  engine            String   @db.VarChar(50)
  bucket_name       String?  @db.VarChar(100)
  object_path       String?  @db.VarChar(255)
  selections_config Json
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now())
  products          products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_semantic_layer_configs_fkey")
}

model sessions {
  app_name    String   @db.VarChar(128)
  user_id     String   @db.VarChar(128)
  id          String   @db.VarChar(128)
  state       Json
  create_time DateTime @db.Timestamp(6)
  update_time DateTime @db.Timestamp(6)
  events      events[]

  @@id([app_name, user_id, id])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model stg_usuarios {
  id                 String?
  username           String?
  email              String?
  password_hash      String?
  iam_role           String?
  client_id          String?
  email_verified     Boolean?
  is_active          Boolean?
  failed_attempts    BigInt?
  locked_until       DateTime? @db.Timestamp(6)
  created_at         DateTime? @db.Timestamp(6)
  updated_at         DateTime? @db.Timestamp(6)
  primary_chatbot_id String?
  can_manage_users   Boolean?
  phoneNumber        String?
  is_active_wsp      Boolean?
  roleAccessId       String?

  @@ignore
}

model user_data_access {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_data_id      String            @db.Uuid
  user_id           String?           @db.Uuid
  table_names       String[]
  data_access       Json?
  metrics_access    Json?
  created_at        DateTime          @default(now())
  updated_at        DateTime
  roles_data_access roles_data_access @relation(fields: [role_data_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "roles_data_access_users_fkey")
  users             users?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_data_access_users_fkey")
}

model user_states {
  app_name    String   @db.VarChar(128)
  user_id     String   @db.VarChar(128)
  state       Json
  update_time DateTime @db.Timestamp(6)

  @@id([app_name, user_id])
}

model users {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username                 String                     @unique
  email                    String?                    @unique
  password_hash            String?
  avatar_data              String?                    @db.Text
  email_verified           Boolean                    @default(false)
  is_active                Boolean                    @default(true)
  failed_attempts          Int                        @default(0)
  locked_until             DateTime?
  created_at               DateTime                   @default(now())
  updated_at               DateTime?
  primary_chatbot_id       String?                    @db.VarChar(255)
  can_manage_users         Boolean?                   @default(false)
  phone_number             String?
  is_active_whatsapp       Boolean?                   @default(false)
  role_acceso_data_id      String?                    @db.Uuid
  role_id                  String?                    @db.Uuid @default("4648f54f-9139-40a2-96d7-c1ac4e936bbf")
  role                     roles?                     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  access_user_client       access_user_client[]
  access_user_organization access_user_organization[]
  access_user_product      access_user_product[]
  access_user_project      access_user_project[]
  user_data_access         user_data_access[]
  conversations            conversations[]
}

model conversations {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  product_id  String?   @db.Uuid
  title       String    @db.VarChar(255)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  is_archived Boolean   @default(false)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages    chat_messages[]

  @@index([user_id], map: "idx_conversations_user")
  @@index([product_id], map: "idx_conversations_product")
}

model chat_messages {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String        @db.Uuid
  role            String        @db.VarChar(20)
  content         String
  message_type    String        @default("text") @db.VarChar(50)
  metadata        Json?
  created_at      DateTime      @default(now())
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id], map: "idx_messages_conversation")
}
