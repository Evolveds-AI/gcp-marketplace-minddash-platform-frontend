import crypto from 'crypto';
import { PrismaClient } from '@prisma/client';
import {
  DataConnector,
  ConnectorType,
  ConnectorStatus,
  SyncType,
  SyncStatus,
  DatabaseConfig,
  ApiConfig,
  FileConfig,
  WebhookConfig,
  SyncLog,
  FieldMapping,
  SyncedData,
  CreateConnectorDTO,
  UpdateConnectorDTO,
  ConnectorResponse,
  ConnectorListResponse,
  SyncResponse,
  SyncConnectorDTO,
  ValidationResult,
  ConnectorMetrics,
  ConnectorFilters,
  ExportOptions,
  ConnectorConfig
} from '@/types/connectors';

const prisma = new PrismaClient();

// Clave de encriptación - en producción debe estar en variables de entorno
const ENCRYPTION_KEY = process.env.CONNECTOR_ENCRYPTION_KEY || 'default-key-change-in-production';
const ALGORITHM = 'aes-256-gcm';

export class ConnectorService {
  /**
   * Encripta datos sensibles de configuración
   */
  private encryptConfig(config: any): string {
    try {
      const iv = crypto.randomBytes(16);
      const cipher = crypto.createCipher(ALGORITHM, ENCRYPTION_KEY);
      
      let encrypted = cipher.update(JSON.stringify(config), 'utf8', 'hex');
      encrypted += cipher.final('hex');
      
      const authTag = cipher.getAuthTag();
      
      return JSON.stringify({
        encrypted,
        iv: iv.toString('hex'),
        authTag: authTag.toString('hex')
      });
    } catch (error) {
      throw new Error('Error al encriptar configuración');
    }
  }

  /**
   * Desencripta datos de configuración
   */
  private decryptConfig(encryptedData: string): any {
    try {
      const { encrypted, iv, authTag } = JSON.parse(encryptedData);
      
      const decipher = crypto.createDecipher(ALGORITHM, ENCRYPTION_KEY);
      decipher.setAuthTag(Buffer.from(authTag, 'hex'));
      
      let decrypted = decipher.update(encrypted, 'hex', 'utf8');
      decrypted += decipher.final('utf8');
      
      return JSON.parse(decrypted);
    } catch (error) {
      throw new Error('Error al desencriptar configuración');
    }
  }

  /**
   * Valida la configuración del conector según su tipo
   */
  private validateConnectorConfig(type: ConnectorType, config: any): ValidationResult {
    const errors: string[] = [];
    
    switch (type) {
      case ConnectorType.DATABASE:
        const dbConfig = config as DatabaseConfig;
        if (!dbConfig.host) errors.push('Host es requerido');
        if (!dbConfig.port) errors.push('Puerto es requerido');
        if (!dbConfig.database) errors.push('Nombre de base de datos es requerido');
        if (!dbConfig.username) errors.push('Usuario es requerido');
        if (!dbConfig.password) errors.push('Contraseña es requerida');
        break;
        
      case ConnectorType.API:
        const apiConfig = config as ApiConfig;
        if (!apiConfig.baseUrl) errors.push('URL base es requerida');
        break;
        
      case ConnectorType.FILE:
        const fileConfig = config as FileConfig;
        if (!fileConfig.path) errors.push('Ruta del archivo es requerida');
        if (!fileConfig.format) errors.push('Formato del archivo es requerido');
        break;
        
      case ConnectorType.WEBHOOK:
        const webhookConfig = config as WebhookConfig;
        if (!webhookConfig.url) errors.push('URL del webhook es requerida');
        if (!webhookConfig.method) errors.push('Método HTTP es requerido');
        break;
    }
    
    return {
      isValid: errors.length === 0,
      errors: errors.map(error => ({
        field: 'config',
        message: error,
        code: 'VALIDATION_ERROR'
      }))
    };
  }

  /**
   * Crea un nuevo conector
   */
  async createConnector(request: CreateConnectorDTO, userId: string): Promise<ConnectorResponse> {
    try {
      // Validar configuración
      const validation = this.validateConnectorConfig(request.type, request.config);
      if (!validation.isValid) {
        throw new Error(`Configuración inválida: ${validation.errors.join(', ')}`);
      }

      // Encriptar configuración sensible
      const encryptedConfig = this.encryptConfig(request.config);

      // Crear conector en base de datos
      const connector = await prisma.dataConnector.create({
        data: {
          name: request.name,
          type: request.type as any,
          config: encryptedConfig,
          status: ConnectorStatus.INACTIVE as any,
          created_by: userId,
          client_id: request.clientId,
          product_id: request.productId
        }
      });

      return {
        success: true,
        data: {
          id: connector.id,
          name: connector.name,
          description: undefined,
          type: connector.type as ConnectorType,
          status: connector.status as ConnectorStatus,
          config: connector.config as unknown as ConnectorConfig,
          clientId: connector.client_id || undefined,
          productId: connector.product_id || undefined,
          createdBy: connector.created_by,
          createdAt: connector.created_at,
          updatedAt: connector.updated_at
        }
      };
    } catch (error) {
      console.error('Error al crear conector:', error);
      return {
        success: false,
        error: error instanceof Error ? error.message : 'Error desconocido'
      };
    }
  }

  /**
   * Obtiene un conector por ID
   */
  async getConnector(id: string): Promise<ConnectorResponse | null> {
    try {
      const connector = await prisma.dataConnector.findUnique({
        where: { id }
      });

      if (!connector) return null;

      return {
        success: true,
        data: {
          id: connector.id,
          name: connector.name,
          description: undefined,
          type: connector.type as ConnectorType,
          status: connector.status as ConnectorStatus,
          config: connector.config as unknown as ConnectorConfig,
          clientId: connector.client_id || undefined,
          productId: connector.product_id || undefined,
          createdBy: connector.created_by,
          createdAt: connector.created_at,
          updatedAt: connector.updated_at
        }
      };
    } catch (error) {
      throw new Error(`Error al obtener conector: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Lista conectores con filtros
   */
  async listConnectors(filter: ConnectorFilters = {}): Promise<ConnectorListResponse> {
    try {
      const whereClause: any = {};
      
      if (filter.type) whereClause.type = filter.type;
      if (filter.status) whereClause.status = filter.status;
      if (filter.clientId) whereClause.client_id = filter.clientId;
      if (filter.productId) whereClause.product_id = filter.productId;
      if (filter.createdBy) whereClause.created_by = filter.createdBy;
      
      if (filter.search) {
        whereClause.OR = [
          { name: { contains: filter.search, mode: 'insensitive' } }
        ];
      }
      
      if (filter.dateRange) {
        whereClause.created_at = {
          gte: filter.dateRange.from,
          lte: filter.dateRange.to
        };
      }

      const limit = filter.limit || 50;
      const offset = filter.offset || 0;
      
      const [connectors, total] = await Promise.all([
        prisma.dataConnector.findMany({
          where: whereClause,
          orderBy: { created_at: 'desc' },
          take: limit,
          skip: offset
        }),
        prisma.dataConnector.count({ where: whereClause })
      ]);

      const dataConnectors: DataConnector[] = connectors.map(connector => ({
        id: connector.id,
        name: connector.name,
        description: undefined,
        type: connector.type as ConnectorType,
        status: connector.status as ConnectorStatus,
        config: connector.config as unknown as ConnectorConfig,
        clientId: connector.client_id || undefined,
        productId: connector.product_id || undefined,
        createdBy: connector.created_by,
        createdAt: connector.created_at,
        updatedAt: connector.updated_at,
        lastSyncAt: connector.last_sync || undefined
      }));

      return {
        success: true,
        data: dataConnectors,
        pagination: {
          page: Math.floor(offset / limit) + 1,
          limit,
          total,
          totalPages: Math.ceil(total / limit)
        }
      };
    } catch (error) {
      return {
        success: false,
        error: `Error al listar conectores: ${error instanceof Error ? error.message : 'Error desconocido'}`
      };
    }
  }

  /**
   * Actualiza un conector
   */
  async updateConnector(id: string, request: UpdateConnectorDTO): Promise<ConnectorResponse> {
    try {
      const updateData: any = {
        updatedAt: new Date()
      };

      if (request.name) updateData.name = request.name;
      if (request.status) updateData.status = request.status;
      
      if (request.config) {
        // Validar nueva configuración
        const connector = await prisma.dataConnector.findUnique({ where: { id } });
        if (!connector) throw new Error('Conector no encontrado');
        
        const validation = this.validateConnectorConfig(connector.type as ConnectorType, request.config);
        if (!validation.isValid) {
          throw new Error(`Configuración inválida: ${validation.errors.join(', ')}`);
        }
        
        updateData.config = this.encryptConfig(request.config);
      }

      const updatedConnector = await prisma.dataConnector.update({
        where: { id },
        data: updateData
      });

      return {
        success: true,
        data: {
          id: updatedConnector.id,
          name: updatedConnector.name,
          description: undefined,
          type: updatedConnector.type as ConnectorType,
          status: updatedConnector.status as ConnectorStatus,
          config: updatedConnector.config as unknown as ConnectorConfig,
          clientId: updatedConnector.client_id || undefined,
          productId: updatedConnector.product_id || undefined,
          createdBy: updatedConnector.created_by,
          createdAt: updatedConnector.created_at,
          updatedAt: updatedConnector.updated_at
        }
      };
    } catch (error) {
      throw new Error(`Error al actualizar conector: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Elimina un conector
   */
  async deleteConnector(id: string): Promise<void> {
    try {
      await prisma.dataConnector.delete({
        where: { id }
      });
    } catch (error) {
      throw new Error(`Error al eliminar conector: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

