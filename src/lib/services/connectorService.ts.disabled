  /**
   * Inicia una sincronización
   */
  async startSync(id: string, request: SyncConnectorDTO): Promise<SyncResponse> {
    try {
      const connector = await prisma.dataConnector.findUnique({ where: { id } });
      if (!connector) throw new Error('Conector no encontrado');

      // Crear log de sincronización
      const syncLog = await prisma.syncLog.create({
        data: {
          connector_id: id,
          status: 'RUNNING' as any,
          started_at: new Date(),
          records_processed: 0,
          records_success: 0,
          records_failed: 0
        }
      });

      // Actualizar estado del conector
      await prisma.dataConnector.update({
        where: { id },
        data: { 
          status: 'SYNCING' as any,
          last_sync: new Date()
        }
      });

      // Aquí se implementaría la lógica de sincronización en background
      // Por ahora simulamos el inicio exitoso

      return {
        success: true,
        syncLogId: syncLog.id,
        message: 'Sincronización iniciada exitosamente'
      };
    } catch (error) {
      throw new Error(`Error al iniciar sincronización: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Obtiene métricas de un conector con filtros avanzados
   */
  async getMetrics(id: string, options: {
    period?: string;
    granularity?: string;
    startDate?: Date;
    endDate?: Date;
  } = {}): Promise<any> {
    try {
      const connector = await prisma.dataConnector.findUnique({ where: { id } });
      if (!connector) throw new Error('Conector no encontrado');

      const { startDate, endDate, granularity = 'hour' } = options;
      
      // Construir filtros de fecha
      const dateFilter: any = {};
      if (startDate) dateFilter.gte = startDate;
      if (endDate) dateFilter.lte = endDate;

      // Obtener logs de sincronización en el rango de fechas
      const syncLogs = await prisma.syncLog.findMany({
        where: {
          connector_id: id,
          ...(Object.keys(dateFilter).length > 0 && { started_at: dateFilter })
        },
        orderBy: { started_at: 'desc' }
      });

      // Calcular métricas agregadas
      const totalSyncs = syncLogs.length;
      const successfulSyncs = syncLogs.filter(log => log.status === 'SUCCESS').length;
      const failedSyncs = syncLogs.filter(log => log.status === 'FAILED').length;
      const totalRecords = syncLogs.reduce((sum, log) => sum + (log.records_processed || 0), 0);

      // Agrupar por granularidad para series temporales
      const timeSeriesData = this.groupSyncLogsByGranularity(syncLogs, granularity);

      return {
        summary: {
          totalSyncs,
          successfulSyncs,
          failedSyncs,
          successRate: totalSyncs > 0 ? (successfulSyncs / totalSyncs) * 100 : 0,
          totalRecords,
          lastSyncAt: connector.last_sync,
          averageSyncDuration: this.calculateAverageSyncDuration(syncLogs)
        },
        timeSeries: timeSeriesData
      };
    } catch (error) {
      throw new Error(`Error al obtener métricas: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Agrupa logs de sincronización por granularidad temporal
   */
  private groupSyncLogsByGranularity(syncLogs: any[], granularity: string): any[] {
    const groups: { [key: string]: any } = {};
    
    syncLogs.forEach(log => {
      if (!log.startedAt) return;
      
      const date = new Date(log.startedAt);
      let key: string;
      
      switch (granularity) {
        case 'hour':
          key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')} ${String(date.getHours()).padStart(2, '0')}:00`;
          break;
        case 'day':
          key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
          break;
        case 'week':
          const weekStart = new Date(date);
          weekStart.setDate(date.getDate() - date.getDay());
          key = `${weekStart.getFullYear()}-W${Math.ceil(weekStart.getDate() / 7)}`;
          break;
        case 'month':
          key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
          break;
        default:
          key = date.toISOString().split('T')[0];
      }
      
      if (!groups[key]) {
        groups[key] = {
          timestamp: key,
          totalSyncs: 0,
          successfulSyncs: 0,
          failedSyncs: 0,
          totalRecords: 0
        };
      }
      
      groups[key].totalSyncs++;
      if (log.status === SyncStatus.COMPLETED) groups[key].successfulSyncs++;
      if (log.status === SyncStatus.FAILED) groups[key].failedSyncs++;
      groups[key].totalRecords += log.recordsProcessed || 0;
    });
    
    return Object.values(groups).sort((a, b) => a.timestamp.localeCompare(b.timestamp));
  }

  /**
   * Obtiene métricas de un conector (método legacy)
   */
  async getConnectorMetrics(id: string): Promise<ConnectorMetrics> {
    try {
      const connector = await prisma.dataConnector.findUnique({ where: { id } });
      if (!connector) throw new Error('Conector no encontrado');

      // Obtener estadísticas de sincronización
      const syncLogs = await prisma.syncLog.findMany({
        where: { connector_id: id },
        orderBy: { started_at: 'desc' },
        take: 10
      });

      const totalSyncs = syncLogs.length;
      const successfulSyncs = syncLogs.filter(log => log.status === 'SUCCESS').length;
      const failedSyncs = syncLogs.filter(log => log.status === 'FAILED').length;
      const totalRecords = syncLogs.reduce((sum, log) => sum + (log.records_processed || 0), 0);

      return {
        connectorId: id,
        totalSyncs,
        successfulSyncs,
        failedSyncs,
        averageSyncTime: this.calculateAverageSyncDuration(syncLogs),
        lastSyncStatus: syncLogs.length > 0 ? syncLogs[0].status as SyncStatus : SyncStatus.PENDING,
        dataVolume: {
          totalRecords,
          recordsToday: 0, // TODO: implementar cálculo
          recordsThisWeek: 0, // TODO: implementar cálculo
          recordsThisMonth: 0 // TODO: implementar cálculo
        }
      };
    } catch (error) {
      throw new Error(`Error al obtener métricas: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Calcula la duración promedio de sincronización
   */
  private calculateAverageSyncDuration(syncLogs: any[]): number {
    const completedSyncs = syncLogs.filter(log => 
      log.status === SyncStatus.COMPLETED && log.startedAt && log.completedAt
    );

    if (completedSyncs.length === 0) return 0;

    const totalDuration = completedSyncs.reduce((sum, log) => {
      const duration = new Date(log.completedAt).getTime() - new Date(log.startedAt).getTime();
      return sum + duration;
    }, 0);

    return totalDuration / completedSyncs.length;
  }

  /**
   * Obtiene la configuración desencriptada de un conector (solo para uso interno)
   */
  async getConnectorConfig(id: string): Promise<any> {
    try {
      const connector = await prisma.dataConnector.findUnique({ where: { id } });
      if (!connector) throw new Error('Conector no encontrado');

      if (!connector.config) {
        throw new Error('Configuración del conector no encontrada');
      }
      return this.decryptConfig(JSON.stringify(connector.config));
    } catch (error) {
      throw new Error(`Error al obtener configuración: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Obtiene los logs de un conector
   */
  async getLogs(connectorId: string, options: {
    page?: number;
    limit?: number;
    level?: string;
    startDate?: Date;
    endDate?: Date;
    search?: string;
  } = {}) {
    try {
      const { page = 1, limit = 50, level, startDate, endDate, search } = options;
      const offset = (page - 1) * limit;

      const where: any = { connectorId };
      
      if (level) where.level = level;
      if (startDate) where.createdAt = { ...where.createdAt, gte: startDate };
      if (endDate) where.createdAt = { ...where.createdAt, lte: endDate };
      if (search) {
        where.OR = [
          { message: { contains: search, mode: 'insensitive' } },
          { metadata: { contains: search, mode: 'insensitive' } }
        ];
      }

      const [logs, total] = await Promise.all([
        prisma.syncLog.findMany({
          where,
          orderBy: { started_at: 'desc' },
          take: limit,
          skip: offset
        }),
        prisma.syncLog.count({ where })
      ]);

      return {
        data: logs,
        total,
        page,
        limit
      };
    } catch (error) {
      throw new Error(`Error al obtener logs: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Limpia los logs de un conector
   */
  async clearLogs(connectorId: string, filters: {
    olderThan?: Date;
    level?: string;
  } = {}) {
    try {
      const where: any = { connectorId };
      
      if (filters.olderThan) {
        where.createdAt = { lt: filters.olderThan };
      }
      
      if (filters.level) {
        where.level = filters.level;
      }

      const result = await prisma.syncLog.deleteMany({ where });
      
      return {
        deletedCount: result.count
      };
    } catch (error) {
      throw new Error(`Error al limpiar logs: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

  /**
   * Limpia las métricas históricas de un conector
   */
  async clearMetrics(connectorId: string, options: {
    olderThan?: Date;
    keepSummary?: boolean;
  } = {}) {
    try {
      const { olderThan, keepSummary = false } = options;
      
      // Verificar que el conector existe
      const connector = await prisma.dataConnector.findUnique({ where: { id: connectorId } });
      if (!connector) throw new Error('Conector no encontrado');

      let deletedRecords = 0;

      // Limpiar logs de sincronización
      const syncLogWhere: any = { connectorId };
      if (olderThan) {
        syncLogWhere.startedAt = { lt: olderThan };
      }
      
      // Si no se mantiene el resumen, eliminar todos los logs
      // Si se mantiene, conservar los últimos registros para métricas básicas
      if (!keepSummary) {
        const syncLogResult = await prisma.syncLog.deleteMany({ where: syncLogWhere });
        deletedRecords += syncLogResult.count;
      } else {
        // Mantener los últimos 10 registros para métricas de resumen
        const logsToKeep = await prisma.syncLog.findMany({
          where: { connector_id: connectorId },
          orderBy: { started_at: 'desc' },
          take: 10,
          select: { id: true }
        });
        
        const keepIds = logsToKeep.map(log => log.id);
        const deleteWhere = {
          ...syncLogWhere,
          id: { notIn: keepIds }
        };
        
        const syncLogResult = await prisma.syncLog.deleteMany({ where: deleteWhere });
        deletedRecords += syncLogResult.count;
      }

      // Limpiar logs del conector
      const connectorLogWhere: any = { connectorId };
      if (olderThan) {
        connectorLogWhere.createdAt = { lt: olderThan };
      }
      
      if (!keepSummary) {
        const syncLogResult = await prisma.syncLog.deleteMany({ where: connectorLogWhere });
        deletedRecords += syncLogResult.count;
      }

      return {
        deletedRecords,
        keptSummary: keepSummary
      };
    } catch (error) {
      throw new Error(`Error al limpiar métricas: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  }

